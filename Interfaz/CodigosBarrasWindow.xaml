<Window x:Class="OperacionTools.Interfaz.CodigosBarrasWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OperacionTools.Interfaz"
        mc:Ignorable="d"
        Title="Visor de Codigos de Barras" Height="600" Width="500"
        WindowStartupLocation="CenterOwner" Background="#1e1e1e">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="🖨️ Imprimir Listado" Padding="15,8" Background="#2980b9"
                    Foreground="white" FontWeight="Bold" BorderThickness="0" 
                    Click="BtnImprimir_Click" Cursor="Hand" Style="{StaticResource BotonModernoStyle}"/>
            
            <TextBlock Text="Fuente:" Foreground="White" VerticalAlignment="Center" Margin="20,0,5,0" FontWeight="Bold"/>

            <ComboBox Width="180" Height="30" VerticalContentAlignment="Center" 
                      ItemsSource="{Binding FuentesDisponibles}"
                      DisplayMemberPath="Key"
                      SelectedValuePath="Value"
                      SelectedValue="{Binding FuenteSeleccionada, Mode=TwoWay}"
                      />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ItemsCodigos">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="white" Margin="0,0,0,12" Padding="20,15" CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding TextoPlano}" FontSize="13" FontWeight="Bold"
                                           Foreground="#333333" HorizontalAlignment="Center" Margin="0,0,0,5"/>

                                <TextBlock Text="{Binding TextoCodigo39}"
                                           FontFamily="{Binding DataContext.FuenteSeleccionada, 
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                           FontSize="60" Foreground="Black"
                                           HorizontalAlignment="Center" Margin="0,2,0,2"
                                           TextOptions.TextFormattingMode="Display"/>

                                <TextBlock Text="* Lector de Soporte *" FontSize="10" Foreground="#7f8c8d"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            
        </ScrollViewer>
    </Grid>
</Window>
