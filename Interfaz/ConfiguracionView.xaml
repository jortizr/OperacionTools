<UserControl x:Class="OperacionTools.Interfaz.ConfiguracionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OperacionTools.Interfaz"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="600" Background="#121212">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
            <TextBlock Text="⚙️ Configuración de Almacenamiento y Red" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>

            <Button Style="{StaticResource BotonModernoStyle}"  Content="❓Tutorial" 
            Margin="15,0,0,0" 
            Padding="10,4"
            Background="#33ffffff"
            Foreground="#FF15F312"
            FontWeight="SemiBold" 
            BorderThickness="0" 
            Cursor="Hand"
            Click="BtnTutorial_Click">
            </Button>
        </StackPanel>

        <StackPanel Grid.Row="1" MaxWidth="500" HorizontalAlignment="Left" Width="406">
            <CheckBox x:Name="ChkUtilizarRed" Content="Habilitar almacenamiento remoto (LAN)." Foreground="White"
                      FontSize="13" Margin="0,0,0,20" IsChecked="False" Checked="ChkUtilizarRed_Changed"
                      Unchecked="ChkUtilizarRed_Changed"/>

            <StackPanel x:Name="PanelCredencialesRed">
                <TextBlock Text="Ruta de Red (Carpeta Compartida UNC):" Foreground="Gray" FontWeight="DemiBold" Margin="0,0,5,5"/>
                <TextBox x:Name="TxtRutaRed" Height="30" Margin="0,0,0,15" VerticalAlignment="Center" FontSize="13"
                         Text="\\ipservidor\Compartido\InventarioData\"/>

                <TextBlock Text="Usuario de Red:" Foreground="Gray" FontWeight="DemiBold" Margin="0,0,5,5"/>
                <TextBox x:Name="TxtUsuarioRed" Height="30" Margin="0,0,0,15" VerticalContentAlignment="Center"
                         FontSize="13"/>

                <TextBlock Text="Contraseña de Red:" Foreground="Gray" Margin="0,0,5,5"/>
                <PasswordBox x:Name="TxtPasswordRed" Height="30" Margin="0,0,0,25" 
                             VerticalContentAlignment="Center"/>
            </StackPanel>
            <Button Content="💾 Guardar Configuración" Width="180" Height="35"
                    Background="#27ae60" Foreground="White" FontWeight="Bold" 
                    BorderThickness="0" Click="BtnGuardar_Click" 
                    Style="{StaticResource BotonModernoStyle}"/>
        </StackPanel>
    </Grid>
</UserControl>
