<Window x:Class="OperacionTools.Interfaz.IdentificacionAuditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OperacionTools.Interfaz"
        mc:Ignorable="d"
        Title="Identificación del Auditor" Height="270" Width="430"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#121212" Foreground="White" WindowStyle="ThreeDBorderWindow">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="👤 Firma de Auditoría de Inventario" Foreground="White" FontSize="15" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Text="Ingrese su código de nómina para firmar la validez del reporte." Foreground="Gray" FontSize="11" Margin="0,0,0,15"/>

            <TextBlock Text="Código de Nómina:" Foreground="LightGray" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtCodigoNomina" Height="30" VerticalContentAlignment="Center" Background="#1a1a1c" Foreground="White" BorderBrush="#333" FontSize="13" Padding="6,0" KeyDown="TxtCodigoNomina_KeyDown" TextChanged="TxtCodigoNomina_TextChanged"/>

            <TextBlock Text="Nombre Completo del Auditor:" Foreground="LightGray" FontWeight="SemiBold" Margin="0,8,0,5"/>
            <TextBox x:Name="TxtNombreCompleto" Height="30" VerticalContentAlignment="Center" Background="#1a1a1c" Foreground="White" BorderBrush="#333" FontSize="13" Padding="6,0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Content="Cancelar" Width="90" Height="32" Background="#c0392b" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,0,10,0" Click="BtnCancelar_Click"/>
                <Button Content="Aceptar" Width="90" Height="32" Background="#27ae60" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnAceptar_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
