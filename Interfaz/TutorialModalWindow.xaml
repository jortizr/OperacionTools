<Window x:Class="OperacionTools.Interfaz.TutorialModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OperacionTools.Interfaz"
        mc:Ignorable="d"
        Title="Guía Rápida de Uso" Height="500" Width="380"
        WindowStartupLocation="CenterOwner" Background="#1a1a1c"
        WindowStyle="ToolWindow" Topmost="True" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock x:Name="TxtIcono" Text="💡" FontSize="24" Margin="0,0,10,0" Foreground="#FFBA0020"/>
            <TextBlock x:Name="TxtTituloModulo" Text="Tutorial de Función" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Visible" Margin="0,0,0,15" Padding="0,0,10,0">
            <StackPanel>
                <Border Background="#2a2a2d" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#FFBA0020" BorderThickness="1,1,1,1">
                    <StackPanel>
                        <TextBlock Text="¿Para qué sirve este módulo?" Foreground="#FFFB9A00" FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>
                        <TextBlock x:Name="TxtDescripcionModulo" Text="Descripción de la funcionalidad..." Foreground="White" FontSize="12" TextWrapping="Wrap" LineHeight="16"/>
                    </StackPanel>
                </Border>
                <TextBlock Text="Paso a paso para operar:" Foreground="Gray" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                
                <ItemsControl x:Name="ListaPasos">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#202022" CornerRadius="8" Padding="12" Margin="0,0,0,10" BorderBrush="#333" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#ba0020" Width="22" Height="22" CornerRadius="11" HorizontalAlignment="Left" VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Numero}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                        <TextBlock Text="{Binding Titulo}" Foreground="White" FontWeight="Bold" FontSize="13" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding Descripcion}" Foreground="#b3b3b3" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <Button Style="{StaticResource BotonModernoStyle}"  Grid.Row="2" Content="¡Entendido, a practicar!" Height="35" Background="#27ae60" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnCerrar_Click" Cursor="Hand">
        </Button>
    </Grid>
</Window>
